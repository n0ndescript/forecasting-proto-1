# Copernicus Climate Data Store (ERA5)
# Already configured via .cdsapirc in the project root or ~/.cdsapirc.
# Sign up at: https://cds.climate.copernicus.eu/
CDSAPI_URL=https://cds.climate.copernicus.eu/api
CDSAPI_KEY=

# NASA Earthdata Login (IMERG)
# Register at: https://urs.earthdata.nasa.gov/users/new
# After registering, also accept the GES DISC EULA:
#   https://disc.gsfc.nasa.gov/earthdata-login
# Credentials are typically stored in ~/.netrc — see README for setup.
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=
